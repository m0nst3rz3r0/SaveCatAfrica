# Local dev — generated by `npx convex dev` into .env.local (do not commit)
# VITE_CONVEX_URL=https://your-project-123.convex.cloud

# Vercel production — set in Vercel dashboard (same production Convex URL):
# VITE_CONVEX_URL=https://your-project-123.convex.cloud

# Convex dashboard → Settings → Environment Variables (Production):
# ADMIN_EMAIL=admin@savecatafrica.org
# ADMIN_PASSWORD=your-secure-password
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
